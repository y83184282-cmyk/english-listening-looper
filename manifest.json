{
    "manifest_version":  3,
    "name":  "English Listening Looper",
    "version":  "0.1.0",
    "description":  "Add, delete, replay, and loop sentence nodes on HTML5 video pages.",
    "icons":  {
                  "16":  "icons/icon16.png",
                  "32":  "icons/icon32.png",
                  "48":  "icons/icon48.png",
                  "128":  "icons/icon128.png"
              },
    "permissions":  [
                        "storage"
                    ],
    "content_scripts":  [
                            {
                                "matches":  [
                                                "http://*/*",
                                                "https://*/*"
                                            ],
                                "js":  [
                                           "content.js"
                                       ],
                                "css":  [
                                            "overlay.css"
                                        ],
                                "run_at":  "document_idle"
                            }
                        ],
    "action":  {
                   "default_title":  "English Listening Looper",
                   "default_icon":  {
                                        "16":  "icons/icon16.png",
                                        "32":  "icons/icon32.png",
                                        "48":  "icons/icon48.png",
                                        "128":  "icons/icon128.png"
                                    }
               }
}
